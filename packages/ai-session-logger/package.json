{
  "name": "ai-session-logger",
  "version": "0.1.0",
  "private": true,
  "description": "Session-aware UI and AI interaction logger for Next.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "default": "./dist/next/index.js"
    },
    "./next/server": {
      "types": "./dist/next/server.d.ts",
      "default": "./dist/next/server.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "typescript": "^5",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true },
    "react": { "optional": true }
  }
}
